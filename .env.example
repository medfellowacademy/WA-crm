# ── Supabase ──────────────────────────────────────────────────────
# From: supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key        # NEVER expose to client

# ── Encryption ────────────────────────────────────────────────────
# 64-char hex key for AES-GCM encryption of WhatsApp tokens & API keys
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Changing this key will invalidate all stored tokens. Back it up.
ENCRYPTION_KEY=your-64-char-hex-key-here

# ── Meta / WhatsApp ───────────────────────────────────────────────
# From: developers.facebook.com → Your App → Settings → Basic → App Secret
META_APP_SECRET=your-meta-app-secret

# ── App URL ───────────────────────────────────────────────────────
# Your production domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Cron Secrets ─────────────────────────────────────────────────
# Random secret strings — must match what Vercel sends in Authorization header
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=your-random-cron-secret
AUTOMATION_CRON_SECRET=your-random-automation-cron-secret

# ── Optional: OpenAI (for AI auto-reply feature) ──────────────────
# Set per-org in Settings → Integrations instead of globally
# OPENAI_API_KEY=sk-...
