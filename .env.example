# ── Supabase ──────────────────────────────────────────────────────
# From: supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key        # NEVER expose to client

# ── Encryption ────────────────────────────────────────────────────
# 64-char hex key for AES-GCM encryption of WhatsApp tokens & API keys
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Changing this key will invalidate all stored tokens. Back it up.
ENCRYPTION_KEY=your-64-char-hex-key-here

# ── Meta / WhatsApp ───────────────────────────────────────────────
# From: developers.facebook.com → Your App → Settings → Basic → App Secret
META_APP_SECRET=your-meta-app-secret

# Embedded Signup (one-click WhatsApp connect). Requires Meta Tech Provider
# status with a WhatsApp Embedded Signup configuration.
#   App ID:    developers.facebook.com → Your App → Settings → Basic → App ID
#   Config ID: Your App → WhatsApp → Embedded Signup → Configuration ID
META_APP_ID=your-meta-app-id
NEXT_PUBLIC_META_APP_ID=your-meta-app-id          # same value, exposed to the browser for FB.init
NEXT_PUBLIC_META_CONFIG_ID=your-embedded-signup-config-id

# ── Native integrations (optional) ────────────────────────────────
# Google Sheets — console.cloud.google.com → APIs & Services → Credentials
# → OAuth client (Web). Authorized redirect URI:
#   {NEXT_PUBLIC_SITE_URL}/api/integrations/google/callback
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Shopify — partners.shopify.com → your app → Client credentials.
# Allowed redirection URL: {NEXT_PUBLIC_SITE_URL}/api/integrations/shopify/callback
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret

# ── App URL ───────────────────────────────────────────────────────
# Your production domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Cron Secrets ─────────────────────────────────────────────────
# Random secret strings — must match what Vercel sends in Authorization header
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=your-random-cron-secret
AUTOMATION_CRON_SECRET=your-random-automation-cron-secret

# ── Optional: OpenAI (for AI auto-reply feature) ──────────────────
# Set per-org in Settings → Integrations instead of globally
# OPENAI_API_KEY=sk-...
